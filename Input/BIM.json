"measures":[
{"name":"Approval Rate","description":"Ratio of approved applications","expression":"DIVIDE(COUNTROWS(FILTER('go_application_fact','go_application_fact'[application_outcome] = \"Approved\")),COUNTROWS('go_application_fact'))","formatString":"0.00%","lineageTag":"f1d3e4d2-1n8e-4a9c-9a0e-8b2c7d1a0e78"},
{"name":"Activation Rate","description":"Ratio of activated to approved applications","expression":"DIVIDE(COUNTROWS(FILTER('go_application_fact','go_application_fact'[application_outcome] = \"Activated\")),COUNTROWS(FILTER('go_application_fact','go_application_fact'[application_outcome] = \"Approved\")))","formatString":"0.00%","lineageTag":"f2d3e4d2-2n8e-4a9c-9a0e-8b2c7d1a0e79"},
{"name":"Average Time to Approval","description":"Avg. days from submission to approval","expression":"AVERAGE('go_application_fact'[approval_date] - 'go_application_fact'[application_submission_date])","formatString":"#,0.00","lineageTag":"f3d3e4d2-3n8e-4a9c-9a0e-8b2c7d1a0e80"},
{"name":"Drop-off Rate","description":"Applications not activated","expression":"DIVIDE(COUNTROWS('go_application_fact') - COUNTROWS(FILTER('go_application_fact','go_application_fact'[application_outcome] = \"Activated\")),COUNTROWS('go_application_fact'))","formatString":"0.00%","lineageTag":"f4d3e4d2-4n8e-4a9c-9a0e-8b2c7d1a0e81"},
{"name":"Cost per Acquisition","description":"Cost per activated application","expression":"DIVIDE(SUM('go_campaign_dimension'[campaign_cost]),COUNTROWS(FILTER('go_application_fact','go_application_fact'[application_outcome] = \"Activated\" && 'go_application_fact'[campaign_id] = 'go_campaign_dimension'[campaign_id])))","formatString":"#,0.00","lineageTag":"f5d3e4d2-5n8e-4a9c-9a0e-8b2c7d1a0e82"},
{"name":"Campaign ROI","description":"Return on investment for campaigns","expression":"DIVIDE(SUM('go_transaction_fact'[first_transaction_amount]) - SUM('go_campaign_dimension'[campaign_cost]),SUM('go_campaign_dimension'[campaign_cost]))","formatString":"#,0.00","lineageTag":"f6d3e4d2-6n8e-4a9c-9a0e-8b2c7d1a0e83"},
{"name":"Conversion Rate","description":"Activated applications rate","expression":"DIVIDE(COUNTROWS(FILTER('go_application_fact','go_application_fact'[application_outcome] = \"Activated\")),COUNTROWS('go_application_fact'))","formatString":"0.00%","lineageTag":"f7d3e4d2-7n8e-4a9c-9a0e-8b2c7d1a0e84"},
{"name":"Decline Rate","description":"Rejected applications rate","expression":"DIVIDE(COUNTROWS(FILTER('go_application_fact','go_application_fact'[application_outcome] = \"Rejected\")),COUNTROWS('go_application_fact'))","formatString":"0.00%","lineageTag":"f8d3e4d2-8n8e-4a9c-9a0e-8b2c7d1a0e85"},
{"name":"Average Credit Score","description":"Avg. applicant credit score","expression":"AVERAGE('go_applicant_dimension'[credit_score])","formatString":"#,0","lineageTag":"f9d3e4d2-9n8e-4a9c-9a0e-8b2c7d1a0e86"},
{"name":"Fraud Detection Rate","description":"Confirmed frauds per application","expression":"DIVIDE(COUNTROWS(FILTER('go_fraud_check_fact','go_fraud_check_fact'[screening_result] = \"Confirmed Fraud\")),COUNTROWS('go_application_fact'))","formatString":"0.00%","lineageTag":"f0d3e4d2-0o8e-4a9c-9a0e-8b2c7d1a0e87"},
{"name":"False Positive Rate","description":"Cleared flagged fraud checks","expression":"DIVIDE(COUNTROWS(FILTER('go_fraud_check_fact','go_fraud_check_fact'[resolution_outcome] = \"Cleared\")),COUNTROWS(FILTER('go_fraud_check_fact','go_fraud_check_fact'[screening_result] = \"Flagged\")))","formatString":"0.00%","lineageTag":"f1d3e4d2-1o8e-4a9c-9a0e-8b2c7d1a0e88"},
{"name":"Escalation Rate","description":"Flagged checks escalated","expression":"DIVIDE(COUNTROWS(FILTER('go_fraud_check_fact','go_fraud_check_fact'[escalation_status] = \"Manual Review\")),COUNTROWS(FILTER('go_fraud_check_fact','go_fraud_check_fact'[screening_result] = \"Flagged\")))","formatString":"0.00%","lineageTag":"f2d3e4d2-2o8e-4a9c-9a0e-8b2c7d1a0e89"},
{"name":"Time to First Transaction","description":"Avg. days from activation to txn","expression":"AVERAGE('go_transaction_fact'[first_transaction_date] - 'go_application_fact'[activation_date])","formatString":"#,0.00","lineageTag":"f3d3e4d2-3o8e-4a9c-9a0e-8b2c7d1a0e90"},
{"name":"Inactive Rate","description":"Activated apps with no txn","expression":"DIVIDE(COUNTROWS(FILTER('go_transaction_fact',ISBLANK('go_transaction_fact'[first_transaction_date]))),COUNTROWS(FILTER('go_application_fact','go_application_fact'[application_outcome] = \"Activated\")))","formatString":"0.00%","lineageTag":"f4d3e4d2-4o8e-4a9c-9a0e-8b2c7d1a0e91"},
{"name":"Average First Transaction Amount","description":"Avg. first transaction amount","expression":"AVERAGE('go_transaction_fact'[first_transaction_amount])","formatString":"#,0.00","lineageTag":"f5d3e4d2-5o8e-4a9c-9a0e-8b2c7d1a0e92"}
]
}
